# ══════════════════════════════════════════════
# Barbearia Turetta — Environment Variables
# Copie este arquivo para .env e preencha os valores.
# ══════════════════════════════════════════════

APP_NAME="Barbearia Turetta"
APP_ENV=production
APP_URL=https://www.barbeariatutetta.com.br
APP_DEBUG=false

# ── Database ──────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=turetta_db
DB_USERNAME=turetta_user
DB_PASSWORD=
DB_CHARSET=utf8mb4

# ── JWT ───────────────────────────────────────
JWT_SECRET=TROCAR_POR_CHAVE_SEGURA_MINIMO_32_CHARS
JWT_TTL=3600
JWT_REFRESH_TTL=604800

# ── E-mail (SMTP) ────────────────────────────
MAIL_HOST=smtp.hostgator.com.br
MAIL_PORT=465
MAIL_USERNAME=contato@turetta.com.br
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_NAME="Barbearia Turetta"
MAIL_FROM_ADDRESS=contato@turetta.com.br
